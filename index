<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>dcamp Family VC League Map – Domain Coverage</title>
  <style>
    :root {
      --bg:#050505;
      --panel:#0f0f10;
      --panel-2:#101011;
      --line:rgba(255,255,255,.10);
      --line-strong:rgba(255,255,255,.18);
      --text:#F5F4EF;
      --muted:#9C9B95;
      --muted-2:#6F6E69;
      --orange:#FF5E27;
      --orange-soft:rgba(255,94,39,.14);
      --shadow:0 24px 80px rgba(0,0,0,.36);
      --radius:28px;
    }
    * { box-sizing:border-box; }
    html, body { height:100%; }
    body {
      margin:0;
      color:var(--text);
      font-family: Inter, Pretendard, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(80vw 80vw at 110% -10%, rgba(255,94,39,.13), transparent 36%),
        linear-gradient(180deg, #050505 0%, #090909 100%);
      letter-spacing:-0.01em;
    }
    a { color:inherit; text-decoration:none; }
    .shell {
      width:min(1280px, calc(100% - 48px));
      margin:0 auto;
      padding:26px 0 28px;
    }
    .topbar {
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      margin-bottom:34px;
    }
    .brand-link {
      font-size:14px;
      color:var(--muted);
      letter-spacing:.02em;
    }
    .nav {
      display:flex;
      align-items:center;
      gap:18px;
      font-size:14px;
      color:var(--muted);
    }
    .nav a.active {
      color:var(--text);
    }
    .title-wrap {
      margin-bottom:20px;
    }
    .title-wrap h1 {
      margin:0 0 8px;
      font-size:clamp(34px, 5vw, 64px);
      line-height:1;
      font-weight:750;
      letter-spacing:-0.04em;
    }
    .title-wrap p {
      margin:0;
      font-size:16px;
      color:var(--muted);
    }
    .canvas {
      position:relative;
      min-height:820px;
      border-radius:var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.025), rgba(255,255,255,.01)),
        var(--panel);
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      overflow:hidden;
    }
    .canvas::before {
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(rgba(255,255,255,.022) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.022) 1px, transparent 1px);
      background-size:36px 36px;
      mask-image:linear-gradient(180deg, rgba(0,0,0,.38), transparent 92%);
      pointer-events:none;
    }
    .chart-stage {
      position:relative;
      width:100%;
      min-height:820px;
    }
    .svg-wrap {
      position:absolute;
      inset:0;
    }
    .raw-grid {
      display:grid;
      grid-template-columns: minmax(0, .95fr) minmax(0, 1.05fr);
      gap:18px;
      margin-top:18px;
      align-items:start;
    }
    .table-panel {
      border-radius:24px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.018), rgba(255,255,255,.008)),
        var(--panel-2);
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      overflow:hidden;
      min-width:0;
    }
    .table-head {
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:18px 20px 14px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    .table-head h2 {
      margin:0;
      font-size:15px;
      font-weight:650;
      letter-spacing:-0.01em;
    }
    .table-wrap {
      overflow:visible;
    }
    table {
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
    }
    thead th {
      background:rgba(16,16,17,.96);
      color:var(--muted);
      font-size:12px;
      font-weight:550;
      text-align:left;
      padding:12px 20px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    tbody tr {
      border-bottom:1px solid rgba(255,255,255,.06);
    }
    tbody tr:last-child {
      border-bottom:none;
    }
    tbody td {
      padding:13px 20px;
      vertical-align:top;
      font-size:13px;
      color:rgba(245,244,239,.92);
    }
    tbody tr:nth-child(odd) td {
      background:rgba(255,255,255,.012);
    }
    tbody td.value {
      text-align:right;
      white-space:nowrap;
      font-variant-numeric: tabular-nums;
    }
    tbody td.stage-cell {
      text-align:center;
    }
    .name-block {
      display:flex;
      flex-direction:column;
      gap:4px;
      min-width:0;
    }
    .name-block strong {
      font-size:13px;
      font-weight:620;
      color:var(--text);
      line-height:1.45;
      word-break:keep-all;
    }
    .name-block span {
      font-size:12px;
      color:var(--muted);
      line-height:1.4;
    }
    .domain-cell {
      color:rgba(245,244,239,.78);
      line-height:1.5;
      word-break:keep-all;
    }
    .stage-pill {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:56px;
      padding:4px 10px;
      border-radius:999px;
      font-size:11px;
      font-weight:650;
      letter-spacing:.02em;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.04);
    }
    .stage-red {
      color:#FF7A57;
      border-color:rgba(255,122,87,.30);
      background:rgba(255,122,87,.08);
    }
    .stage-green {
      color:#92D98A;
      border-color:rgba(146,217,138,.28);
      background:rgba(146,217,138,.08);
    }
    .stage-blue {
      color:#7EA9FF;
      border-color:rgba(126,169,255,.28);
      background:rgba(126,169,255,.08);
    }
    .table-note {
      padding:14px 20px 18px;
      border-top:1px solid rgba(255,255,255,.06);
      font-size:12px;
      color:var(--muted);
      line-height:1.5;
    }
    .tooltip {
      position:fixed;
      z-index:12;
      min-width:198px;
      max-width:260px;
      padding:12px 12px 11px;
      border-radius:16px;
      background:rgba(12,12,12,.96);
      border:1px solid rgba(255,255,255,.14);
      box-shadow:0 16px 48px rgba(0,0,0,.38);
      color:var(--text);
      pointer-events:none;
      opacity:0;
      transform:translate(-50%, calc(-100% - 14px));
      transition:opacity .12s ease;
      backdrop-filter:blur(8px);
    }
    .tooltip.visible { opacity:1; }
    .tooltip .t-title {
      font-size:13px;
      font-weight:700;
      margin-bottom:6px;
    }
    .tooltip .t-note {
      font-size:12px;
      color:var(--muted);
      line-height:1.45;
      margin-bottom:6px;
    }
    .tooltip .t-row {
      display:flex;
      justify-content:space-between;
      gap:12px;
      font-size:12px;
      color:var(--muted);
      line-height:1.5;
    }
    .tooltip .t-row strong {
      color:var(--text);
      font-weight:650;
    }
    svg text {
      font-family: Inter, Pretendard, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    @media (max-width: 1100px) {
      .raw-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 960px) {
      .shell {
        width:min(100%, calc(100% - 24px));
        padding-top:18px;
      }
      .topbar {
        margin-bottom:24px;
      }
      .nav {
        gap:12px;
        font-size:13px;
      }
      .canvas, .chart-stage {
        min-height:760px;
      }
    }
  </style>
</head>

      svg += `</g></svg>`;
      root.innerHTML = svg;

      root.querySelectorAll('.bubble-hit').forEach(el => {
        const domain = el.getAttribute('data-domain');
        const d = DATA.domains.find(item => item.domain === domain);
        el.addEventListener('mouseenter', evt => showTooltip(evt, d));
        el.addEventListener('mousemove', moveTooltip);
        el.addEventListener('mouseleave', hideTooltip);
      });
    }

    window.addEventListener('resize', () => {
      clearTimeout(window.__dcampResizeTimer);
      window.__dcampResizeTimer = setTimeout(renderCoverage, 80);
    });

    renderCoverage();
  </script>
</body>
</html>
